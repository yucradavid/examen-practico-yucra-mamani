<group name="local,ssh,">

  <!--
    Regla personalizada de fuerza bruta SSH.
    Detecta intentos fallidos SSH clasificados por Wazuh con la regla 5710
    y genera una alerta local de severidad 10 para evidenciar el ataque.
  -->
  <rule id="100000" level="10">
    <if_sid>5710</if_sid>
    <description>Ataque de fuerza bruta SSH detectado desde $(srcip)</description>
    <group>authentication_failures,brute_force,</group>
  </rule>

</group>
